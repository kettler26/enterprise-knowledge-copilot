OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral-small:latest
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=copilot_chunks
# RAG citation quality
RAG_MIN_VECTOR_SCORE=0.28
RAG_MAX_CITATIONS=6
RAG_MAX_VECTOR=4
RAG_MAX_KEYWORD=2
API_PORT=8000
WEB_PORT=3000
# SQLite path for runs + ingested docs (default: ./copilot.db in API cwd)
APP_DB_PATH=./copilot.db
# DuckDB analytics (rolling metrics, default ./analytics.duckdb)
DUCKDB_PATH=./analytics.duckdb
# Langfuse (optional — leave empty to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# OpenTelemetry OTLP HTTP (optional — Phoenix: often http://localhost:6006/v1/traces)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=saas-copilot-api
